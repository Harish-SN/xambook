# ---------- Logs ----------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- Node / frontend ----------
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
dist
dist-ssr
*.local

# ---------- Go / backend ----------
backend/tmp/
backend/*.exe

# ---------- Secrets (NEVER commit) ----------
.env
*.env
.env.local
.env.production

# ---------- Terraform ----------
# Ignore STATE and local var/secret files, but KEEP the .tf source code.
# (Do NOT add a bare "terraform/" line — it would drop all your infra code.)
**/.terraform/*
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
crash.log
crash.*.log

# ---------- Kubeconfig / cluster creds (NEVER commit) ----------
*.kubeconfig
admin.conf
kubeconfig

# ---------- Editor / IDE ----------
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---------- OS ----------
.DS_Store
Thumbs.db

# -----------data---------
data/